<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="App name"
        android:gravity="center"
        android:padding="24dp"
        android:textSize="28sp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnStartTour"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="spread"  />

    <Button
        android:id="@+id/btnStartTour"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start Tour"
        android:textSize="22sp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:backgroundTint="#00FFFF"
        android:textColor="#000000"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintBottom_toTopOf="@id/btnBookVisit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnBookVisit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Book a visit"
        android:textSize="22sp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:backgroundTint="#00FFFF"
        android:textColor="#000000"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnStartTour"
        app:layout_constraintBottom_toTopOf="@id/btnMeetCounselor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnMeetCounselor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Meet your admission counselor"
        android:textSize="22sp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:backgroundTint="#00FFFF"
        android:textColor="#000000"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/btnBookVisit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>