<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBackground"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:padding="24dp"
        android:text="DipGuide"
        android:textColor="@color/mainTextColor"
        android:textSize="42sp"
        app:layout_constraintBottom_toTopOf="@id/btnStartTour"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="spread" />

    <Button
        android:id="@+id/btnStartTour"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start Tour"
        android:textSize="22sp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:backgroundTint="@color/buttonColor"
        android:textColor="@color/buttonTextColor"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintBottom_toTopOf="@id/btnBookVisit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnBookVisit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Book a visit"
        android:textSize="22sp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:backgroundTint="@color/buttonColor"
        android:textColor="@color/buttonTextColor"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        app:layout_constraintTop_toBottomOf="@id/btnStartTour"
        app:layout_constraintBottom_toTopOf="@id/btnMeetCounselor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnMeetCounselor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Meet your admission counselor"
        android:textSize="22sp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:backgroundTint="@color/buttonColor"
        android:textColor="@color/buttonTextColor"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        app:layout_constraintTop_toBottomOf="@id/btnBookVisit"
        app:layout_constraintBottom_toTopOf="@id/btnContactInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnContactInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Contact Info"
        android:textSize="22sp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:backgroundTint="@color/buttonColor"
        android:textColor="@color/buttonTextColor"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        app:layout_constraintTop_toBottomOf="@id/btnMeetCounselor"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>